[Unit]
Description=Office Recorder -> Fireflies
# Do NOT order after time-sync.target — the app records pre-NTP and gates only uploads in-app.
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=%i
EnvironmentFile=/etc/office-recorder.env
WorkingDirectory=/opt/office-recorder
ExecStart=/opt/office-recorder/.venv/bin/python -m recorder.main
Restart=always
RestartSec=3
KillMode=mixed
KillSignal=SIGINT
TimeoutStopSec=40

[Install]
WantedBy=multi-user.target
